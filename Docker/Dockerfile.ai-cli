FROM node:24-bookworm-slim

ARG ARG_UV_VERSION
ARG ARG_PYTHON_VERSION
ARG ARG_PLAYWRIGHT_CLI_VERSION
ARG ARG_HIMALAYA_VERSION
ARG ARG_TEA_VERSION

# Basics + socat for the codex login bridge
RUN apt-get update && apt-get install -y --no-install-recommends \
    git ca-certificates bash curl socat wget jq sudo vim unzip gpg gnupg apt-transport-https lsb-release tree bc tmux openssh-server cron rclone poppler-utils ripgrep file && \
    rm -rf /var/lib/apt/lists/*

RUN printf '%s\n' \
    'set -g default-terminal "tmux-256color"' \
    'set -as terminal-overrides ",xterm-256color:RGB"' \
    'set -g mouse on' \
    'set -g history-limit 100000' \
    > /etc/tmux.conf

# Install GitHub CLI
RUN mkdir -p -m 755 /etc/apt/keyrings && \
    wget -qO /etc/apt/keyrings/githubcli-archive-keyring.gpg https://cli.github.com/packages/githubcli-archive-keyring.gpg && \
    chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" > /etc/apt/sources.list.d/github-cli.list && \
    apt-get update && apt-get install -y --no-install-recommends gh && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Install Himalaya (pinned Linux x86_64 release)
RUN set -e; \
    curl -fsSL \
        -o /tmp/himalaya.tar.gz \
        https://github.com/pimalaya/himalaya/releases/download/${ARG_HIMALAYA_VERSION}/himalaya.x86_64-linux.tgz; \
    mkdir -p /tmp/himalaya; \
    tar -xzf /tmp/himalaya.tar.gz -C /tmp/himalaya; \
    install -m 0755 /tmp/himalaya/himalaya /usr/local/bin/himalaya; \
    rm -rf /tmp/himalaya /tmp/himalaya.tar.gz

# Install tea (pinned Linux amd64 release)
RUN set -e; \
    curl -fsSL \
        -o /tmp/tea \
        https://dl.gitea.com/tea/${ARG_TEA_VERSION}/tea-${ARG_TEA_VERSION}-linux-amd64; \
    install -m 0755 /tmp/tea /usr/local/bin/tea; \
    rm -f /tmp/tea

# Install uv
RUN set -e; \
    curl -fsSL \
        -o /tmp/uv.tar.gz \
        https://github.com/astral-sh/uv/releases/download/${ARG_UV_VERSION}/uv-x86_64-unknown-linux-gnu.tar.gz; \
    tar -xzf /tmp/uv.tar.gz -C /tmp; \
    install -m 755 /tmp/uv-x86_64-unknown-linux-gnu/uv /usr/local/bin/uv; \
    install -m 755 /tmp/uv-x86_64-unknown-linux-gnu/uvx /usr/local/bin/uvx; \
    rm -rf /tmp/uv.tar.gz /tmp/uv-x86_64-unknown-linux-gnu

ENV UV_PYTHON_INSTALL_DIR=/opt/python

# Install Python using uv
RUN uv python install --install-dir /opt/python ${ARG_PYTHON_VERSION}

# Create a default virtual environment
RUN uv venv /opt/venv
ENV VIRTUAL_ENV=/opt/venv
ENV PATH="/opt/venv/bin:$PATH"

RUN printf '%s\n' \
    'case ":$PATH:" in' \
    '  *:/opt/venv/bin:*) ;;' \
    '  *) export PATH="/opt/venv/bin:$PATH" ;;' \
    'esac' \
    > /etc/profile.d/ai-cli-venv-path.sh

# Install pip into the venv so pip commands work
RUN uv pip install pip

# Install ALL CLIs
RUN npm i -g @anthropic-ai/claude-code @openai/codex @github/copilot

# Playwright CLI + browser dependencies (Chromium only to keep the image smaller)
RUN npm i -g @playwright/cli@${ARG_PLAYWRIGHT_CLI_VERSION} \
    && mv /usr/local/bin/playwright-cli /usr/local/bin/playwright-cli-bin \
    && printf '%s\n' '#!/usr/bin/env bash' 'set -e' '' 'REAL_PLAYWRIGHT_CLI="/usr/local/bin/playwright-cli-bin"' '' 'if [ "${1:-}" = "open" ]; then' '  shift' '  has_browser=0' '  for arg in "$@"; do' '    case "$arg" in' '      --browser|--browser=*)' '        has_browser=1' '        ;;' '    esac' '  done' '' '  if [ "$has_browser" -eq 0 ]; then' '    exec "$REAL_PLAYWRIGHT_CLI" open --browser=chromium "$@"' '  fi' '  exec "$REAL_PLAYWRIGHT_CLI" open "$@"' 'fi' '' 'exec "$REAL_PLAYWRIGHT_CLI" "$@"' > /usr/local/bin/playwright-cli \
    && chmod +x /usr/local/bin/playwright-cli \
    && npx -p @playwright/cli@${ARG_PLAYWRIGHT_CLI_VERSION} playwright install-deps chromium

# MCP scripts are optional; keep the directory for custom servers
RUN mkdir -p /opt/mcp

# Bundle project helper scripts that should always be available in the image
COPY scripts/mdserver.py /usr/local/bin/mdserver
COPY scripts/ai-shell-enable-cron.sh /usr/local/bin/ai-shell-enable-cron
COPY scripts/ai-shell-enable-ssh.sh /usr/local/bin/ai-shell-enable-ssh
COPY scripts/ai-shell-entrypoint.sh /usr/local/bin/ai-shell-entrypoint
RUN chmod +x /usr/local/bin/mdserver
RUN chmod +x /usr/local/bin/ai-shell-enable-cron /usr/local/bin/ai-shell-enable-ssh /usr/local/bin/ai-shell-entrypoint

# Copy extensions directory and install custom Python packages
COPY extensions /opt/extensions
RUN if [ -s /opt/extensions/requirements.txt ]; then \
        echo "Installing packages from requirements.txt..." && \
        uv pip install -r /opt/extensions/requirements.txt; \
    fi && \
    if ls /opt/extensions/packages/*.whl 1> /dev/null 2>&1; then \
        echo "Installing wheel files from packages/..." && \
        uv pip install /opt/extensions/packages/*.whl; \
    fi

# Set timezone
ENV TZ=Europe/Amsterdam
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

# Create non-root user and set permissions
RUN useradd -m -s /bin/bash aiuser && \
    chown -R aiuser:aiuser /opt/venv /opt/python /opt/mcp /opt/extensions

# Switch to non-root user
USER aiuser

# Workdir; no ENTRYPOINT (set per service in compose)
WORKDIR /workspace
